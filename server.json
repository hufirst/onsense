{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-16/server.schema.json",
  "name": "io.github.hufirst/onsense",
  "description": "Android phone camera, sensors & files for any MCP client — local, no cloud, no ADB.",
  "repository": {
    "url": "https://github.com/hufirst/onsense",
    "source": "github"
  },
  "version": "0.3.11",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "onsense",
      "version": "0.3.11",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve"
        }
      ]
    }
  ]
}
